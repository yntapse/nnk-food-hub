# Copy this file to .env and fill in your values

# MySQL Connection URL (Prisma) — LOCAL DEVELOPMENT
# Local MySQL: mysql://root:password@localhost:3306/food_delivery
DATABASE_URL=mysql://root:password@localhost:3306/food_delivery

# PostgreSQL Connection URL — PRODUCTION (Neon, Supabase, etc.)
# Uncomment and use this for production deployments on Koyeb/Fly.io:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret Key (change to a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port (optional, Railway sets automatically)
PORT=8080

# Optional ping message for /api/ping
PING_MESSAGE=pong

# API base URL — leave empty for web, set to Railway backend URL for Android APK builds
# VITE_API_URL=https://your-app.up.railway.app
VITE_API_URL=

# Razorpay Keys (get from https://dashboard.razorpay.com -> Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

