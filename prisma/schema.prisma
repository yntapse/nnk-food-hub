generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  phone     String
  address   String   @default("")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rider {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  name          String
  phone         String
  isOnline      Boolean  @default(false)
  isAvailable   Boolean  @default(false)
  totalEarnings Float    @default(0)
  rating        Float    @default(5)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Hotel {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  password      String
  name          String
  phone         String
  location      String
  category      String     @default("Fast Food")
  rating        Float      @default(4.5)
  totalOrders   Int        @default(0)
  totalEarnings Float      @default(0)
  isOpen            Boolean    @default(true)
  upiId             String     @default("")
  razorpayAccountId String     @default("")
  menuItems         MenuItem[]
  orders            Order[]
  settlements       SettlementRequest[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model SettlementRequest {
  id        Int      @id @default(autoincrement())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelId   Int
  amount    Float
  upiId     String
  status    String   @default("pending") // pending | paid
  paidAt    DateTime?
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  price       Float
  category    String   @default("Main Course")
  image       String   @default("")
  isAvailable Boolean  @default(true)
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  upiId     String   @default("")
  deliveryFeeAmount    Float    @default(30)
  freeDeliveryThreshold Float   @default(200)
  firstOrderFree       Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              Int      @id @default(autoincrement())
  user            User     @relation(fields: [userId], references: [id])
  userId          Int
  hotel           Hotel    @relation(fields: [hotelId], references: [id])
  hotelId         Int
  rider           Rider?   @relation(fields: [riderId], references: [id])
  riderId         Int?
  items           Json
  totalPrice      Float
  itemsPrice      Float    @default(0)
  deliveryFee     Float    @default(0)
  deliveryAddress String
  paymentMethod   String   @default("COD")
  paymentId       String   @default("")
  razorpayOrderId String   @default("")
  platformFee     Float    @default(0)
  hotelPayout     Float    @default(0)
  transferId      String   @default("")
  customerPhone   String   @default("")
  status          String   @default("Placed")
  deliveryOtp     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
